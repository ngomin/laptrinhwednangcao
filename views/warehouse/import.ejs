<%- include('../partials/layout-start') %>

<div class="max-w-xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/warehouse/import" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Sản phẩm <span class="text-rose-500">*</span></label>
        <select name="productId" required class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="">— Chọn sản phẩm —</option>
          <% products.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.name %> (Tồn: <%= p.stock %> <%= p.unit %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Số lượng nhập <span class="text-rose-500">*</span></label>
          <input type="number" name="quantity" required min="1" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Đơn giá nhập (đ)</label>
          <input type="number" name="unitCost" min="0" step="1000" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500" placeholder="Để trống = dùng giá nhập mặc định">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Nhà cung cấp</label>
        <select name="supplierId" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="">— Chọn nhà cung cấp —</option>
          <% suppliers.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Ghi chú</label>
        <textarea name="note" rows="3" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500"></textarea>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <a href="/warehouse" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Xác nhận nhập kho
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
