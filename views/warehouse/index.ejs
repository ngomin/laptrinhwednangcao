<%- include('../partials/layout-start') %>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <p class="text-xs text-slate-500 mb-1">Lượt nhập tháng này</p>
    <p class="text-xl font-bold text-emerald-600"><%= stats.monthImports %></p>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <p class="text-xs text-slate-500 mb-1">Lượt xuất tháng này</p>
    <p class="text-xl font-bold text-rose-600"><%= stats.monthExports %></p>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <p class="text-xs text-slate-500 mb-1">Tổng giá trị nhập</p>
    <p class="text-xl font-bold text-slate-800"><%= formatCurrency(stats.totalImportValue) %></p>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <p class="text-xs text-slate-500 mb-1">Tổng giao dịch</p>
    <p class="text-xl font-bold text-slate-800"><%= stats.totalImports + stats.totalExports %></p>
  </div>
</div>

<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
  <form method="GET" class="flex flex-wrap items-center gap-2 flex-1">
    <select name="type" onchange="this.form.submit()" class="px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
      <option value="">Tất cả loại</option>
      <option value="import" <%= filters.type === 'import' ? 'selected' : '' %>>Nhập kho</option>
      <option value="export" <%= filters.type === 'export' ? 'selected' : '' %>>Xuất kho</option>
      <option value="adjust" <%= filters.type === 'adjust' ? 'selected' : '' %>>Điều chỉnh</option>
    </select>
    <input type="date" name="from" value="<%= filters.from %>" class="px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
    <input type="date" name="to" value="<%= filters.to %>" class="px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
    <button type="submit" class="px-4 py-2 rounded-lg bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium">Lọc</button>
  </form>
  <div class="flex gap-2">
    <a href="/warehouse/import" class="bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg">Nhập kho</a>
    <a href="/warehouse/export" class="bg-rose-600 hover:bg-rose-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg">Xuất kho</a>
    <a href="/warehouse/adjust" class="bg-slate-700 hover:bg-slate-800 text-white text-sm font-medium px-4 py-2.5 rounded-lg">Điều chỉnh</a>
  </div>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
        <tr>
          <th class="text-left px-5 py-3 font-medium">Loại</th>
          <th class="text-left px-5 py-3 font-medium">Sản phẩm</th>
          <th class="text-right px-5 py-3 font-medium">Số lượng</th>
          <th class="text-left px-5 py-3 font-medium">Nhà cung cấp</th>
          <th class="text-left px-5 py-3 font-medium">Thời gian</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if (transactions.length === 0) { %>
          <tr><td colspan="5" class="px-5 py-10 text-center text-slate-400">Không có giao dịch nào.</td></tr>
        <% } %>
        <% transactions.forEach(t => { %>
          <tr class="table-row-hover">
            <td class="px-5 py-3.5">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium
                <%= t.type === 'import' ? 'bg-emerald-100 text-emerald-700' : t.type === 'export' ? 'bg-rose-100 text-rose-700' : 'bg-amber-100 text-amber-700' %>">
                <%= t.type === 'import' ? 'Nhập kho' : t.type === 'export' ? 'Xuất kho' : 'Điều chỉnh' %>
              </span>
            </td>
            <td class="px-5 py-3.5 font-medium text-slate-700"><%= t.productName %></td>
            <td class="px-5 py-3.5 text-right font-medium <%= t.quantity >= 0 ? 'text-emerald-600' : 'text-rose-600' %>">
              <%= t.quantity >= 0 ? '+' : '' %><%= t.quantity %> <%= t.unit %>
            </td>
            <td class="px-5 py-3.5 text-slate-600"><%= t.supplierName || '—' %></td>
            <td class="px-5 py-3.5 text-slate-500"><%= moment(t.createdAt).format('DD/MM/YYYY HH:mm') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/layout-end') %>
