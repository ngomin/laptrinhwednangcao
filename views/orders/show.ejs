<%- include('../partials/layout-start') %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white border border-slate-200 rounded-xl p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h2 class="text-xl font-bold text-slate-800"><%= order.code %></h2>
          <p class="text-sm text-slate-500 mt-1"><%= moment(order.orderDate).format('DD/MM/YYYY HH:mm') %></p>
        </div>
        <span class="inline-flex px-3 py-1 rounded-full text-xs font-medium
          <% if (order.status === 'completed') { %>bg-emerald-100 text-emerald-700
          <% } else if (order.status === 'cancelled') { %>bg-rose-100 text-rose-700
          <% } else if (order.status === 'delivering') { %>bg-sky-100 text-sky-700
          <% } else if (order.status === 'confirmed') { %>bg-violet-100 text-violet-700
          <% } else { %>bg-amber-100 text-amber-700<% } %>">
          <%= order.status === 'completed' ? 'Hoàn thành' : order.status === 'cancelled' ? 'Đã huỷ' : order.status === 'delivering' ? 'Đang giao' : order.status === 'confirmed' ? 'Đã xác nhận' : 'Chờ xử lý' %>
        </span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-5 pb-5 border-b border-slate-100">
        <div>
          <p class="text-xs text-slate-500 mb-1">Khách hàng</p>
          <p class="text-sm font-medium text-slate-700"><%= customer ? customer.name : 'N/A' %></p>
        </div>
        <div>
          <p class="text-xs text-slate-500 mb-1">Phương thức TT</p>
          <p class="text-sm font-medium text-slate-700">
            <%= order.paymentMethod === 'cash' ? 'Tiền mặt' : order.paymentMethod === 'transfer' ? 'Chuyển khoản' : 'Thẻ' %>
          </p>
        </div>
        <div>
          <p class="text-xs text-slate-500 mb-1">Trạng thái TT</p>
          <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium <%= order.paymentStatus === 'paid' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
            <%= order.paymentStatus === 'paid' ? 'Đã thanh toán' : 'Chưa thanh toán' %>
          </span>
        </div>
      </div>

      <!-- Order items -->
      <table class="w-full text-sm mb-4">
        <thead class="text-slate-500 text-xs uppercase">
          <tr>
            <th class="text-left pb-2 font-medium">Sản phẩm</th>
            <th class="text-right pb-2 font-medium">SL</th>
            <th class="text-right pb-2 font-medium">Đơn giá</th>
            <th class="text-right pb-2 font-medium">Thành tiền</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% details.forEach(d => { %>
            <tr>
              <td class="py-2.5 text-slate-700"><%= d.productName %></td>
              <td class="py-2.5 text-right text-slate-600"><%= d.quantity %> <%= d.unit %></td>
              <td class="py-2.5 text-right text-slate-600"><%= formatCurrency(d.unitPrice) %></td>
              <td class="py-2.5 text-right font-medium text-slate-800"><%= formatCurrency(d.total) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="space-y-1.5 text-sm pt-3 border-t border-slate-100">
        <div class="flex justify-between text-slate-600"><span>Tạm tính</span><span><%= formatCurrency(order.subtotal) %></span></div>
        <div class="flex justify-between text-slate-600"><span>Giảm giá</span><span>- <%= formatCurrency(order.discount) %></span></div>
        <div class="flex justify-between text-slate-600"><span>Thuế</span><span><%= formatCurrency(order.tax) %></span></div>
        <div class="flex justify-between text-base font-bold text-slate-800 pt-1.5 border-t border-slate-100">
          <span>Tổng cộng</span><span><%= formatCurrency(order.total) %></span>
        </div>
      </div>

      <% if (order.note) { %>
        <div class="mt-4 pt-4 border-t border-slate-100">
          <p class="text-xs text-slate-500 mb-1">Ghi chú</p>
          <p class="text-sm text-slate-600"><%= order.note %></p>
        </div>
      <% } %>
    </div>
  </div>

  <div class="space-y-6">
    <!-- Update status -->
    <div class="bg-white border border-slate-200 rounded-xl p-5">
      <h3 class="text-sm font-semibold text-slate-800 mb-3">Cập nhật trạng thái</h3>
      <form action="/orders/<%= order.id %>/status" method="POST" class="space-y-3">
        <select name="status" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Chờ xử lý</option>
          <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Đã xác nhận</option>
          <option value="delivering" <%= order.status === 'delivering' ? 'selected' : '' %>>Đang giao</option>
          <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Hoàn thành</option>
          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Đã huỷ</option>
        </select>
        <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium py-2.5 rounded-lg">Cập nhật</button>
      </form>
    </div>

    <!-- Update payment -->
    <div class="bg-white border border-slate-200 rounded-xl p-5">
      <h3 class="text-sm font-semibold text-slate-800 mb-3">Cập nhật thanh toán</h3>
      <form action="/orders/<%= order.id %>/payment" method="POST" class="space-y-3">
        <select name="paymentStatus" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="pending" <%= order.paymentStatus === 'pending' ? 'selected' : '' %>>Chưa thanh toán</option>
          <option value="paid" <%= order.paymentStatus === 'paid' ? 'selected' : '' %>>Đã thanh toán</option>
        </select>
        <button type="submit" class="w-full bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium py-2.5 rounded-lg">Cập nhật</button>
      </form>
    </div>

    <% if (order.status === 'cancelled') { %>
      <div class="bg-white border border-slate-200 rounded-xl p-5">
        <form action="/orders/<%= order.id %>/delete" method="POST" class="confirm-delete" data-confirm-message="Xoá đơn hàng <%= order.code %>? Hành động này không thể hoàn tác.">
          <button type="submit" class="w-full bg-rose-50 hover:bg-rose-100 text-rose-700 text-sm font-medium py-2.5 rounded-lg">Xoá đơn hàng</button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/layout-end') %>
