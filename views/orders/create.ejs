<%- include('../partials/layout-start') %>

<div class="max-w-4xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/orders/create" method="POST" class="space-y-6">

      <!-- Thông tin chung -->
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Khách hàng <span class="text-rose-500">*</span></label>
          <select name="customerId" required class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
            <option value="">— Chọn khách hàng —</option>
            <% customers.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %> (<%= c.code %>)</option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Phương thức thanh toán</label>
          <select name="paymentMethod" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
            <option value="cash">Tiền mặt</option>
            <option value="transfer">Chuyển khoản</option>
            <option value="card">Thẻ</option>
          </select>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Ngày giao hàng dự kiến</label>
          <input type="date" name="deliveryDate" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Ghi chú</label>
          <input type="text" name="note" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500" placeholder="Ghi chú đơn hàng...">
        </div>
      </div>

      <!-- Danh sách sản phẩm -->
      <div>
        <div class="flex items-center justify-between mb-3">
          <label class="block text-sm font-medium text-slate-700">Sản phẩm trong đơn <span class="text-rose-500">*</span></label>
          <p class="text-xs text-slate-400">Chọn sản phẩm và nhập số lượng cho từng dòng cần dùng</p>
        </div>

        <div class="border border-slate-200 rounded-lg overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 text-slate-500 text-xs uppercase">
              <tr>
                <th class="text-left px-4 py-2.5 font-medium w-1/2">Sản phẩm</th>
                <th class="text-right px-4 py-2.5 font-medium">Số lượng</th>
                <th class="text-right px-4 py-2.5 font-medium">Đơn giá</th>
                <th class="text-right px-4 py-2.5 font-medium">Giảm giá</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% for (let i = 0; i < 5; i++) { %>
                <tr>
                  <td class="px-4 py-2.5">
                    <select name="productIds" class="order-product-select w-full px-2.5 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500"
                            data-row="<%= i %>">
                      <option value="">— Không chọn —</option>
                      <% products.forEach(p => { %>
                        <option value="<%= p.id %>"
                                data-price="<%= p.salePrice %>"
                                data-unit="<%= p.unit %>"
                                data-name="<%= p.name %>"
                                data-stock="<%= p.stock %>">
                          <%= p.name %> (Tồn: <%= p.stock %> <%= p.unit %>)
                        </option>
                      <% }) %>
                    </select>
                    <input type="hidden" name="productNames" class="product-name-input" data-row="<%= i %>">
                    <input type="hidden" name="units" class="unit-input" data-row="<%= i %>">
                  </td>
                  <td class="px-4 py-2.5">
                    <input type="number" name="quantities" min="0" value="0"
                           class="quantity-input w-24 ml-auto block px-2.5 py-2 rounded-lg border border-slate-300 text-sm text-right focus:ring-2 focus:ring-brand-500" data-row="<%= i %>">
                  </td>
                  <td class="px-4 py-2.5">
                    <input type="number" name="unitPrices" min="0" step="1000"
                           class="price-input w-28 ml-auto block px-2.5 py-2 rounded-lg border border-slate-300 text-sm text-right focus:ring-2 focus:ring-brand-500" data-row="<%= i %>">
                  </td>
                  <td class="px-4 py-2.5">
                    <input type="number" name="itemDiscounts" min="0" step="1000" value="0"
                           class="w-24 ml-auto block px-2.5 py-2 rounded-lg border border-slate-300 text-sm text-right focus:ring-2 focus:ring-brand-500">
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-slate-400 mt-2">Chỉ những dòng có số lượng &gt; 0 mới được tính vào đơn hàng.</p>
      </div>

      <!-- Giảm giá & thuế tổng đơn -->
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Giảm giá tổng đơn (đ)</label>
          <input type="number" name="discount" min="0" step="1000" value="0" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Thuế (đ)</label>
          <input type="number" name="tax" min="0" step="1000" value="0" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2 border-t border-slate-100 mt-2">
        <a href="/orders" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Tạo đơn hàng
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Khi chọn sản phẩm ở 1 dòng -> tự điền đơn giá, tên SP, đơn vị tương ứng
  document.querySelectorAll('.order-product-select').forEach(select => {
    select.addEventListener('change', function () {
      const row = this.dataset.row;
      const opt = this.options[this.selectedIndex];
      const price = opt.dataset.price || '';
      const unit = opt.dataset.unit || '';
      const name = opt.dataset.name || '';

      document.querySelector(`.price-input[data-row="${row}"]`).value = price;
      document.querySelector(`.unit-input[data-row="${row}"]`).value = unit;
      document.querySelector(`.product-name-input[data-row="${row}"]`).value = name;

      const qtyInput = document.querySelector(`.quantity-input[data-row="${row}"]`);
      if (opt.value && qtyInput.value == 0) qtyInput.value = 1;
    });
  });
</script>

<%- include('../partials/layout-end') %>
