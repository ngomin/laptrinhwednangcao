<%- include('../partials/layout-start') %>

<link rel="stylesheet" href="/css/categories.css">

<div class="max-w-xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/categories/create" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Tên danh mục <span class="text-rose-500">*</span></label>
        <input type="text" name="name" required autofocus value="<%= category.name || '' %>"
               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
               placeholder="VD: Điện tử">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Mô tả</label>
        <textarea name="description" rows="3"
                  class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                  placeholder="Mô tả ngắn về danh mục..."><%= category.description || '' %></textarea>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <a href="/categories" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Thêm danh mục
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>