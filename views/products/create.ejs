<%- include('../partials/layout-start') %>

<div class="max-w-2xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/products/create" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Tên sản phẩm <span class="text-rose-500">*</span></label>
        <input type="text" name="name" required autofocus value="<%= product.name || '' %>"
               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
               placeholder="VD: Bàn phím cơ Logitech K120">
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Danh mục</label>
          <select name="categoryId" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
            <option value="">— Chọn danh mục —</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Nhà cung cấp</label>
          <select name="supplierId" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
            <option value="">— Chọn nhà cung cấp —</option>
            <% suppliers.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Đơn vị tính</label>
          <input type="text" name="unit" value="Cái" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Tồn kho ban đầu</label>
          <input type="number" name="stock" value="0" min="0" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Tồn kho tối thiểu</label>
          <input type="number" name="minStock" value="10" min="0" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Giá nhập (đ) <span class="text-rose-500">*</span></label>
          <input type="number" name="costPrice" required min="0" step="1000"
                 class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Giá bán (đ) <span class="text-rose-500">*</span></label>
          <input type="number" name="salePrice" required min="0" step="1000"
                 class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Mô tả</label>
        <textarea name="description" rows="3"
                  class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500"></textarea>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <a href="/products" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Thêm sản phẩm
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
