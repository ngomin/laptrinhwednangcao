<%- include('../partials/layout-start') %>

<link rel="stylesheet" href="/css/customers.css">

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-lg font-bold text-slate-800"><%= customer.name %></h2>
        <p class="text-sm text-slate-500"><%= customer.code %></p>
      </div>
      <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium <%= customer.type === 'wholesale' ? 'bg-violet-100 text-violet-700' : 'bg-sky-100 text-sky-700' %>">
        <%= customer.type === 'wholesale' ? 'Khách sỉ' : 'Khách lẻ' %>
      </span>
    </div>
    <div class="space-y-3 text-sm">
      <div class="flex justify-between"><span class="text-slate-500">Điện thoại</span><span class="font-medium text-slate-700"><%= customer.phone || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Email</span><span class="font-medium text-slate-700"><%= customer.email || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Địa chỉ</span><span class="font-medium text-slate-700 text-right max-w-[60%]"><%= customer.address || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Tổng đơn hàng</span><span class="font-medium text-slate-700"><%= customer.totalOrders %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Tổng chi tiêu</span><span class="font-semibold text-emerald-600"><%= formatCurrency(customer.totalSpent) %></span></div>
    </div>
    <% if (customer.note) { %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <p class="text-xs text-slate-500 mb-1">Ghi chú</p>
        <p class="text-sm text-slate-600"><%= customer.note %></p>
      </div>
    <% } %>
    <a href="/customers/<%= customer.id %>/edit" class="mt-6 block text-center bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg">
      Sửa thông tin
    </a>
  </div>

  <div class="lg:col-span-2 bg-white border border-slate-200 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Lịch sử đơn hàng (<%= orders.length %>)</h3>
    </div>
    <div class="divide-y divide-slate-100">
      <% if (orders.length === 0) { %>
        <p class="text-sm text-slate-400 px-5 py-4">Chưa có đơn hàng nào.</p>
      <% } %>
      <% orders.forEach(o => { %>
        <a href="/orders/<%= o.id %>" class="flex items-center justify-between px-5 py-3.5 hover:bg-slate-50">
          <div>
            <p class="text-sm font-medium text-slate-800"><%= o.code %></p>
            <p class="text-xs text-slate-400"><%= moment(o.orderDate).format('DD/MM/YYYY') %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-semibold text-slate-800"><%= formatCurrency(o.total) %></p>
            <span class="text-xs px-2 py-0.5 rounded-full
              <% if (o.status === 'completed') { %>bg-emerald-100 text-emerald-700
              <% } else if (o.status === 'cancelled') { %>bg-rose-100 text-rose-700
              <% } else { %>bg-amber-100 text-amber-700<% } %>">
              <%= o.status === 'completed' ? 'Hoàn thành' : o.status === 'cancelled' ? 'Đã huỷ' : o.status === 'delivering' ? 'Đang giao' : o.status === 'confirmed' ? 'Đã xác nhận' : 'Chờ xử lý' %>
            </span>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/layout-end') %>
