<%- include('../partials/layout-start') %>

<link rel="stylesheet" href="/css/customers.css">

<div class="max-w-2xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/customers/<%= customer.id %>/edit" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Tên khách hàng <span class="text-rose-500">*</span></label>
        <input type="text" name="name" required value="<%= customer.name %>"
               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Số điện thoại</label>
          <input type="text" name="phone" value="<%= customer.phone || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
          <input type="email" name="email" value="<%= customer.email || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Địa chỉ</label>
        <input type="text" name="address" value="<%= customer.address || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Loại khách hàng</label>
        <select name="type" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="retail" <%= customer.type === 'retail' ? 'selected' : '' %>>Khách lẻ</option>
          <option value="wholesale" <%= customer.type === 'wholesale' ? 'selected' : '' %>>Khách sỉ</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Ghi chú</label>
        <textarea name="note" rows="3" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500"><%= customer.note || '' %></textarea>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <a href="/customers" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Lưu thay đổi
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
