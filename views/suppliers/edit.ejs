<%- include('../partials/layout-start') %>

<div class="max-w-2xl">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <form action="/suppliers/<%= supplier.id %>/edit" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Tên nhà cung cấp <span class="text-rose-500">*</span></label>
        <input type="text" name="name" required value="<%= supplier.name %>"
               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Người liên hệ</label>
          <input type="text" name="contact" value="<%= supplier.contact || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Số điện thoại</label>
          <input type="text" name="phone" value="<%= supplier.phone || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
          <input type="email" name="email" value="<%= supplier.email || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Mã số thuế</label>
          <input type="text" name="taxCode" value="<%= supplier.taxCode || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Địa chỉ</label>
        <input type="text" name="address" value="<%= supplier.address || '' %>" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Trạng thái</label>
        <select name="status" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="active" <%= supplier.status === 'active' ? 'selected' : '' %>>Đang hợp tác</option>
          <option value="inactive" <%= supplier.status === 'inactive' ? 'selected' : '' %>>Ngừng hợp tác</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1.5">Ghi chú</label>
        <textarea name="note" rows="3" class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-brand-500"><%= supplier.note || '' %></textarea>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <a href="/suppliers" class="px-4 py-2.5 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100">Huỷ</a>
        <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-colors">
          Lưu thay đổi
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/layout-end') %>
