<%- include('../partials/layout-start') %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="bg-white border border-slate-200 rounded-xl p-6">
    <div class="flex items-start justify-between mb-4">
      <h2 class="text-lg font-bold text-slate-800"><%= supplier.name %></h2>
      <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium <%= supplier.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
        <%= supplier.status === 'active' ? 'Đang hợp tác' : 'Ngừng hợp tác' %>
      </span>
    </div>
    <div class="space-y-3 text-sm">
      <div class="flex justify-between"><span class="text-slate-500">Người liên hệ</span><span class="font-medium text-slate-700"><%= supplier.contact || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Điện thoại</span><span class="font-medium text-slate-700"><%= supplier.phone || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Email</span><span class="font-medium text-slate-700"><%= supplier.email || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Mã số thuế</span><span class="font-medium text-slate-700"><%= supplier.taxCode || '—' %></span></div>
      <div class="flex justify-between"><span class="text-slate-500">Địa chỉ</span><span class="font-medium text-slate-700 text-right max-w-[60%]"><%= supplier.address || '—' %></span></div>
    </div>
    <% if (supplier.note) { %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <p class="text-xs text-slate-500 mb-1">Ghi chú</p>
        <p class="text-sm text-slate-600"><%= supplier.note %></p>
      </div>
    <% } %>
    <a href="/suppliers/<%= supplier.id %>/edit" class="mt-6 block text-center bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg">
      Sửa thông tin
    </a>
  </div>

  <div class="lg:col-span-2 bg-white border border-slate-200 rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Sản phẩm cung cấp (<%= products.length %>)</h3>
    </div>
    <div class="divide-y divide-slate-100">
      <% if (products.length === 0) { %>
        <p class="text-sm text-slate-400 px-5 py-4">Chưa cung cấp sản phẩm nào.</p>
      <% } %>
      <% products.forEach(p => { %>
        <a href="/products/<%= p.id %>" class="flex items-center justify-between px-5 py-3.5 hover:bg-slate-50">
          <div>
            <p class="text-sm font-medium text-slate-800"><%= p.name %></p>
            <p class="text-xs text-slate-400"><%= p.code %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-semibold text-slate-800"><%= formatCurrency(p.salePrice) %></p>
            <p class="text-xs text-slate-400">Tồn: <%= p.stock %> <%= p.unit %></p>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/layout-end') %>
